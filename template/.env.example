# Hold instance template — environment

# better-auth
BETTER_AUTH_SECRET=change-me-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3100

# Auth store: a privileged connection to the project db for better-auth's own
# tables (user/session/account/verification). In dev this is the superuser; in
# production use a dedicated role scoped to the better-auth tables.
HOLD_AUTH_DB_URL=postgres://postgres:postgres@localhost:5433/proj_appdemo

# App data: the project's pooled connection (authenticator role via Supavisor,
# transaction mode). The app SET ROLE authenticated + injects request.jwt.claims
# per transaction, so RLS applies. Comes from the control plane's createProject.
HOLD_DB_URL=postgres://proj_appdemo.appdemo:CHANGE_ME@localhost:6543/proj_appdemo
