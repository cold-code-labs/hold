# Postgres (shared core)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# Control plane -> Postgres admin connection
HOLD_DB_ADMIN_URL=postgres://postgres:postgres@localhost:5433/postgres
HOLD_CONTROL_DB=hold
