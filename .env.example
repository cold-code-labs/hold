# Postgres (shared core)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# Control plane -> Postgres admin connection
HOLD_DB_ADMIN_URL=postgres://postgres:postgres@localhost:5433/postgres
HOLD_CONTROL_DB=hold
HOLD_API_PORT=8787

# Auth — project zero (GoTrue) + panel JWT verification
# Generate a strong secret: openssl rand -hex 32
HOLD_JWT_SECRET=change-me-openssl-rand-hex-32
HOLD_ZERO_DB=hold_zero
HOLD_GOTRUE_URL=http://localhost:9999
HOLD_MASTER_EMAIL=admin@example.com

# Supavisor (multi-tenant pooler). Needs a `_supabase` metadata db.
#   SECRET_KEY_BASE: openssl rand -base64 48   ·   VAULT_ENC_KEY: 32 chars
SUPAVISOR_SECRET_KEY_BASE=change-me-openssl-rand-base64-48
SUPAVISOR_VAULT_ENC_KEY=change-me-32-characters-exactly00
SUPAVISOR_API_JWT_SECRET=change-me-openssl-rand-hex-32
